#!/bin/bash
# focus-iterm-session <session-uuid>
# Activates iTerm2 and selects the session whose unique id matches.
# Invoked when the user clicks a claude-notify notification.

UUID="$1"

# Defense-in-depth: reject anything that doesn't look like a UUID.
if [[ ! "$UUID" =~ ^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{12}$ ]]; then
  echo "focus-iterm-session: invalid UUID '$UUID'" >&2
  exit 1
fi

osascript <<EOF
tell application "iTerm"
  activate
  repeat with w in windows
    repeat with t in tabs of w
      repeat with s in sessions of t
        if unique id of s is "$UUID" then
          select s
          return
        end if
      end repeat
    end repeat
  end repeat
end tell
EOF
